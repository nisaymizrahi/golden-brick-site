{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "golden-brick-construction",
    "public": ".",
    "headers": [
      {
        "source": "/staff",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          }
        ]
      },
      {
        "source": "/staff/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          }
        ]
      },
      {
        "source": "/staff/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          }
        ]
      },
      {
        "source": "/client",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          }
        ]
      },
      {
        "source": "/client/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          }
        ]
      },
      {
        "source": "/client/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/client/**",
        "destination": "/client/index.html"
      },
      {
        "source": "/estimate/**",
        "destination": "/estimate/index.html"
      },
      {
        "source": "/api/public/lead-intake",
        "function": {
          "functionId": "publicLeadIntake",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/auth/sync-session",
        "function": {
          "functionId": "syncStaffSession",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/staff/lead-customer-link",
        "function": {
          "functionId": "syncLeadCustomerLink",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/staff/convert-lead",
        "function": {
          "functionId": "convertLeadToProject",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/staff/estimate-share",
        "function": {
          "functionId": "estimateShare",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/staff/estimate-draft",
        "function": {
          "functionId": "generateEstimateDraft",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/public/estimate-view",
        "function": {
          "functionId": "publicEstimateView",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/public/estimate-sign",
        "function": {
          "functionId": "publicEstimateSign",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/public/agreement-document",
        "function": {
          "functionId": "publicAgreementDocument",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/client/**",
        "function": {
          "functionId": "clientPortalApi",
          "region": "us-central1"
        }
      }
    ],
    "ignore": [
      "firebase.json",
      ".gitignore",
      ".firebaserc",
      ".git/**",
      "**/.git/**",
      ".firebase/**",
      "**/.firebase/**",
      ".playwright-cli/**",
      "**/.playwright-cli/**",
      "output/**",
      "**/output/**",
      ".DS_Store",
      "**/.DS_Store",
      "images/projects/in-progress/**",
      "images/projects/completed/**",
      "images/projects/README.md",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
