rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDocExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDocExists() ? userDoc().data : null;
    }

    function requestEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function allowedStaffDocExists() {
      return requestEmail() != "" &&
        exists(/databases/$(database)/documents/allowedStaff/$(requestEmail()));
    }

    function allowedStaffData() {
      return get(/databases/$(database)/documents/allowedStaff/$(requestEmail())).data;
    }

    function isApprovedStaffEmail() {
      return allowedStaffDocExists() && allowedStaffData().active == true;
    }

    function isActiveStaff() {
      return userData() != null && userData().active == true;
    }

    function isAdmin() {
      return isActiveStaff() && userData().role == "admin";
    }

    function listHas(listValue, uid) {
      return listValue is list && listValue.hasAny([uid]);
    }

    function canReadLead(leadData) {
      return isAdmin() || (
        isActiveStaff() &&
        leadData.assignedToUid == request.auth.uid
      );
    }

    function employeeCanUpdateLeadWithoutWinning() {
      return !(
        resource.data.status != request.resource.data.status &&
        request.resource.data.status == "closed_won"
      );
    }

    function canReadProject(projectData) {
      return isAdmin() || (
        isActiveStaff() &&
        projectData.allowedStaffUids is list &&
        projectData.allowedStaffUids.hasAny([request.auth.uid])
      );
    }

    function canReadCustomer(customerData) {
      return isAdmin() || (
        isActiveStaff() &&
        customerData.allowedStaffUids is list &&
        customerData.allowedStaffUids.hasAny([request.auth.uid])
      );
    }

    function canReadTask(taskData) {
      return isAdmin() || (
        isActiveStaff() &&
        taskData.assignedToUid == request.auth.uid
      );
    }

    function canReadVendorDocument(documentData) {
      return isAdmin() || (
        isActiveStaff() &&
        documentData.accessLevel != "admin_only"
      );
    }

    function canReadRecordDocument(documentData) {
      return isAdmin() || (
        isActiveStaff() && (
          (
            documentData.projectId is string &&
            documentData.projectId != "" &&
            exists(/databases/$(database)/documents/projects/$(documentData.projectId)) &&
            canReadProject(get(/databases/$(database)/documents/projects/$(documentData.projectId)).data)
          ) || (
            documentData.leadId is string &&
            documentData.leadId != "" &&
            exists(/databases/$(database)/documents/leads/$(documentData.leadId)) &&
            canReadLead(get(/databases/$(database)/documents/leads/$(documentData.leadId)).data)
          ) || (
            documentData.customerId is string &&
            documentData.customerId != "" &&
            exists(/databases/$(database)/documents/customers/$(documentData.customerId)) &&
            canReadCustomer(get(/databases/$(database)/documents/customers/$(documentData.customerId)).data)
          )
        )
      );
    }

    function canWriteRecordDocument(documentData) {
      return canReadRecordDocument(documentData);
    }

    match /allowedStaff/{staffKey} {
      allow read: if isAdmin() || (signedIn() && requestEmail() == staffKey);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        signedIn() &&
        requestEmail() == staffKey &&
        resource.data.email == requestEmail() &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.active == resource.data.active &&
        request.resource.data.defaultLeadAssignee == resource.data.defaultLeadAssignee
      );
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId && (isActiveStaff() || isApprovedStaffEmail()));
      allow create: if isAdmin() || (
        signedIn() &&
        request.auth.uid == userId &&
        isApprovedStaffEmail() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == requestEmail() &&
        request.resource.data.role == allowedStaffData().role &&
        request.resource.data.active == true &&
        request.resource.data.defaultLeadAssignee == allowedStaffData().defaultLeadAssignee
      );
      allow update: if isAdmin() || (
        signedIn() &&
        request.auth.uid == userId &&
        isApprovedStaffEmail() &&
        resource.data.email == requestEmail() &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == allowedStaffData().role &&
        request.resource.data.active == true &&
        request.resource.data.defaultLeadAssignee == allowedStaffData().defaultLeadAssignee
      );
      allow delete: if isAdmin();
    }

    match /clientUsers/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow get: if canReadLead(resource.data);
      allow list: if isAdmin() || (
        isActiveStaff() &&
        request.auth.uid == resource.data.assignedToUid
      );
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        canReadLead(resource.data) &&
        employeeCanUpdateLeadWithoutWinning() &&
        request.resource.data.assignedToUid == resource.data.assignedToUid &&
        request.resource.data.assignedToName == resource.data.assignedToName &&
        request.resource.data.assignedToEmail == resource.data.assignedToEmail &&
        request.resource.data.customerId == resource.data.customerId &&
        request.resource.data.customerName == resource.data.customerName
      );
      allow delete: if isAdmin();

      match /activities/{activityId} {
        allow read: if canReadLead(get(/databases/$(database)/documents/leads/$(leadId)).data) || (
          exists(/databases/$(database)/documents/projects/$(leadId)) &&
          canReadProject(get(/databases/$(database)/documents/projects/$(leadId)).data)
        );
        allow create, update: if isAdmin() || canReadLead(get(/databases/$(database)/documents/leads/$(leadId)).data);
        allow delete: if isAdmin();
      }
    }

    match /estimates/{estimateId} {
      function leadDoc() {
        return get(/databases/$(database)/documents/leads/$(estimateId));
      }

      function leadDocExists() {
        return exists(/databases/$(database)/documents/leads/$(estimateId));
      }

      allow get, list: if leadDocExists() && canReadLead(leadDoc().data);
      allow write: if isAdmin();
    }

    match /estimateShares/{shareId} {
      allow get, list: if isActiveStaff();
      allow create, update, delete: if isAdmin();
    }

    match /agreements/{agreementId} {
      allow get, list: if isActiveStaff();
      allow create, update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow get: if canReadCustomer(resource.data);
      allow list: if isAdmin() || (
        isActiveStaff() &&
        resource.data.allowedStaffUids is list &&
        resource.data.allowedStaffUids.hasAny([request.auth.uid])
      );
      allow create, update, delete: if isAdmin();

      match /contacts/{contactId} {
        allow get, list: if isAdmin();
        allow create, update, delete: if isAdmin();
      }

      match /threads/{threadId} {
        allow get, list: if canReadCustomer(get(/databases/$(database)/documents/customers/$(customerId)).data);
        allow create, update, delete: if canReadCustomer(get(/databases/$(database)/documents/customers/$(customerId)).data);

        match /messages/{messageId} {
          allow get, list: if canReadCustomer(get(/databases/$(database)/documents/customers/$(customerId)).data);
          allow create, update, delete: if canReadCustomer(get(/databases/$(database)/documents/customers/$(customerId)).data);
        }
      }
    }

    match /vendors/{vendorId} {
      allow get, list: if isActiveStaff();
      allow create, update, delete: if isAdmin();
    }

    match /vendorBills/{billId} {
      allow get, list: if isActiveStaff();
      allow create, update, delete: if isAdmin();
    }

    match /vendorDocuments/{documentId} {
      allow get, list: if canReadVendorDocument(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /recordDocuments/{documentId} {
      allow get, list: if canReadRecordDocument(resource.data);
      allow create, update: if isAdmin() || canWriteRecordDocument(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow get: if canReadTask(resource.data);
      allow list: if isAdmin() || (
        isActiveStaff() &&
        request.auth.uid == resource.data.assignedToUid
      );
      allow create: if isAdmin() || (
        isActiveStaff() &&
        request.resource.data.assignedToUid == request.auth.uid
      );
      allow update: if isAdmin() || (
        canReadTask(resource.data) &&
        request.resource.data.assignedToUid == resource.data.assignedToUid &&
        request.resource.data.assignedToName == resource.data.assignedToName &&
        request.resource.data.assignedToEmail == resource.data.assignedToEmail
      );
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if canReadProject(resource.data);
      allow list: if isAdmin() || (
        isActiveStaff() &&
        resource.data.allowedStaffUids is list &&
        resource.data.allowedStaffUids.hasAny([request.auth.uid])
      );
      allow create, update, delete: if isAdmin();

      match /expenses/{expenseId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update: if isAdmin() || canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow delete: if isAdmin();
      }

      match /payments/{paymentId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update, delete: if isAdmin();
      }

      match /invoices/{invoiceId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update, delete: if isAdmin();
      }

      match /changeOrders/{changeOrderId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update: if isAdmin() || canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow delete: if isAdmin();
      }

      match /scopeItems/{scopeItemId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update: if isAdmin() || canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow delete: if isAdmin();
      }

      match /documents/{documentId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update: if isAdmin() || canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow delete: if isAdmin();
      }

      match /notes/{noteId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, update: if isAdmin() || canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow delete: if isAdmin();
      }

      match /activities/{activityId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create: if isAdmin() || canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow update, delete: if isAdmin();
      }
    }
  }
}
